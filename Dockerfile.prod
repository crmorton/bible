FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY api.py .
COPY en_bcv_parser.js .

# Copy database
COPY bible_v2.db /app/bible_v2.db

# Set environment variables
ENV DB_PATH=/app/bible_v2.db
ENV LOAD_IN_MEMORY=true
ENV PORT=8080

# Expose port (8080 is default for Cloud Run)
EXPOSE 8080

# Run the application
CMD ["python", "api.py"]
