<service>
  <id>BibleAPI</id>
  <name>Bible API Server</name>
  <description>High-performance read-only Bible API server using SQLite in-memory.</description>
  <executable>%BASE%\..\..\.venv\Scripts\python.exe</executable>
  <argument>%BASE%\..\..\api.py</argument>
  <workingdirectory>%BASE%\..</workingdirectory>
  
  <env name="PORT" value="7777" />
  <env name="WEB_CONCURRENCY" value="3" />
  
  <log mode="roll"></log>
  
  <onfailure action="restart" delay="10 sec"/>
</service>
